rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Construction ledger: any signed-in SLIP account may read and write.
    // Because there is no public sign-up flow (accounts are created by an
    // admin in the Firebase console), "signed in" already means "trusted
    // SLIP team member" for this app's current scope.
    match /construction_ledger/{entryId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
